<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".EscolhaCurriculo">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:background="#2E7D52"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preenchimento de Dados"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="normal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Adicione os dados da empresa desejada"
                android:textColor="#A8D5BB"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F5F2EC"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <!-- Label + Campo: Cargo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CARGO DA VAGA"
                android:textColor="#5F5E5A"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/info1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:startIconTint="#2E7D52"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/white"
                app:boxBackgroundColor="@color/white"
                app:errorEnabled="true"
                app:errorTextColor="#FF6B6B"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/info1Input"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Ex: Desenvolvedor Android"
                    android:inputType="text"
                    android:textColor="#1C1C1C"
                    android:textColorHint="#AAAAAA"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Label + Campo: Descrição -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIÇÃO DA VAGA"
                android:textColor="#5F5E5A"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/info2"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:startIconTint="#2E7D52"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/white"
                app:boxBackgroundColor="@color/white"
                app:errorEnabled="true"
                app:errorTextColor="#FF6B6B"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/info2Input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Descreva as responsabilidades e requisitos..."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:textColor="#1C1C1C"
                    android:textColorHint="#AAAAAA"
                    android:textSize="14sp"
                    android:gravity="top" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Label + Campo: Palavras-chave -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PALAVRAS-CHAVE"
                android:textColor="#5F5E5A"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/info3"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:startIconTint="#2E7D52"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/white"
                app:boxBackgroundColor="@color/white"
                app:errorEnabled="true"
                app:errorTextColor="#FF6B6B"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/info3Input"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Ex: Kotlin, Android, REST API"
                    android:inputType="text"
                    android:textColor="#1C1C1C"
                    android:textColorHint="#AAAAAA"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botões -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/continuar"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="2"
                    android:backgroundTint="#2E7D52"
                    android:text="Criar Curriculo"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>