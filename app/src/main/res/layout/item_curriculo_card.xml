<?xml version="1.0" encoding="utf-8"?>
<!-- item_curriculo_card.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Ícone do tipo de currículo -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_icon"
            android:layout_marginEnd="14dp">

            <ImageView
                android:id="@+id/ivCurriculoIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_description"
                android:contentDescription="Ícone currículo" />

        </FrameLayout>

        <!-- Textos: nome e data -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCurriculoNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Currículo Principal"
                android:textSize="15sp"
                android:textColor="#111111"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvCurriculoSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Atualizado em 01/06/2025"
                android:textSize="12sp"
                android:textColor="#999999"
                tools:ignore="HardcodedText" />

            <!-- Badge de status -->
            <TextView
                android:id="@+id/tvCurriculoStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Completo"
                android:textSize="11sp"
                android:textColor="#2E7D32"
                android:background="@drawable/bg_badge_green"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                tools:ignore="HardcodedText" />

        </LinearLayout>

        <!-- Botão de menu (três pontos) -->
        <ImageView
            android:id="@+id/ivCurriculoMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_more_vert"
            android:padding="4dp"
            android:contentDescription="Opções"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>