<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7"
    tools:context=".Rumo">

    <!-- ===== APP BAR ===== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <!-- Logo / Título "Rumo" -->
            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="rumo"
                android:textSize="26sp"
                android:textColor="#111111"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium" />

            <!-- Ícone de perfil redondo (canto direito) -->
            <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:src="@drawable/ic_person"
                android:background="@drawable/bg_circle_profile"
                android:padding="8dp"
                android:scaleType="centerCrop"
                android:contentDescription="Perfil do usuário"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless" />

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>


    <!-- ===== CONTEÚDO PRINCIPAL ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ===== SEÇÃO: CARROSSEL ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Em destaque"
                android:textSize="13sp"
                android:textColor="#888888"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <!-- Carrossel horizontal (RecyclerView com scroll horizontal) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCarousel"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_carousel_card" />

            <!-- Indicador de pontos do carrossel -->
            <LinearLayout
                android:id="@+id/llCarouselIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Os pontos são adicionados dinamicamente via código -->
                <!-- Exemplo estático para preview: -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_dot_active" />
                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_dot_inactive" />
                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dot_inactive" />

            </LinearLayout>

            <!-- ===== DIVISOR ===== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="28dp"
                android:background="#EBEBEB" />

            <!-- ===== SEÇÃO: MEUS CURRÍCULOS ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvMeusCurriculos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Meus currículos"
                    android:textSize="20sp"
                    android:textColor="#111111"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <!-- Botão "+" para adicionar novo currículo -->
                <ImageView
                    android:id="@+id/ivAddCurriculo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_add"
                    android:background="@drawable/bg_circle_add"
                    android:padding="8dp"
                    android:contentDescription="Adicionar currículo"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless" />

            </LinearLayout>

            <!-- Lista de cards de currículos -->
            <!-- Usando RecyclerView (recomendado) com scroll desabilitado pois está dentro do NestedScrollView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCurriculos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_curriculo_card"
                tools:itemCount="3" />

            <!-- Estado vazio (visível quando não há currículos) -->
            <LinearLayout
                android:id="@+id/llEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_document_empty"
                    android:alpha="0.3"
                    android:contentDescription="Nenhum currículo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Nenhum currículo ainda"
                    android:textSize="15sp"
                    android:textColor="#AAAAAA"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===== FAB (opcional) ===== -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNovoCurriculo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Novo currículo"
        app:srcCompat="@drawable/ic_add"
        app:backgroundTint="#111111"
        app:tint="#FFFFFF"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>