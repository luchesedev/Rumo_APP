<?xml version="1.0" encoding="utf-8"?>
<!-- divider_gradient.xml -->
<!-- Linha divisória com gradiente que desvanece nas pontas (visual refinado) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#00EBEBEB"
        android:centerColor="#FFEBEBEB"
        android:endColor="#00EBEBEB" />

    <size android:height="1dp" />

</shape>